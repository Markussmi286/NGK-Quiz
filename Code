messages: [{
role: "user",
content: `Search for the og:image meta tag URL from this page: ${BASE_URL}${slug}/
Return ONLY the image URL, nothing else. It looks like: https://www.norbert-gymnasium.de/wp-c
}]
})
});
const data = await response.json();
const text = data.content?.map(b => b.text || "").join("") || "";
const match = text.match(/https:\/\/www\.norbert-gymnasium\.de\/wp-content\/uploads\/conn
